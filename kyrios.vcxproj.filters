<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ItemGroup>
    <ApplicationDefinition Include="src\App.xaml" />
  </ItemGroup>
  <ItemGroup>
    <Page Include="src\MainWindow.xaml" />
  </ItemGroup>
  <ItemGroup>
    <Midl Include="src\MainWindow.idl" />
  </ItemGroup>
  <ItemGroup>
    <ClCompile Include="src\pch.cpp" />
    <ClCompile Include="$(GeneratedFilesDir)module.g.cpp" />
    <ClCompile Include="src\TaskItem.cpp" />
    <ClCompile Include="src\TaskDataStore.cpp" />
  </ItemGroup>
  <ItemGroup>
    <ClInclude Include="src\pch.h" />
    <ClInclude Include="src\TaskItem.h" />
    <ClInclude Include="src\TaskDataStore.h" />
  </ItemGroup>
  <ItemGroup>
    <Image Include="Assets\LockScreenLogo.png" />
    <Image Include="Assets\SplashScreen.png" />
    <Image Include="Assets\Square150x150Logo.png" />
    <Image Include="Assets\Square44x44Logo.png" />
    <Image Include="Assets\StoreLogo.png" />
    <Image Include="Assets\Wide310x150Logo.png" />
  </ItemGroup>
  <ItemGroup>
    <None Include="packages.config" />
  </ItemGroup>
  <ItemGroup>
    <Natvis Include="$(MSBuildThisFileDirectory)..\..\natvis\wil.natvis" />
    <Natvis Include="$(MSBuildThisFileDirectory)..\..\natvis\wil.natstepfilter" />
  </ItemGroup>
  <ItemGroup>
    <ResourceCompile Include="src\kyrios.rc" />
  </ItemGroup>
  <ItemGroup>
    <AppxManifest Include="Package.appxmanifest" />
  </ItemGroup>
</Project>