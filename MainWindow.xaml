<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="WindToDo.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WindToDo"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Froggy">

    <Border BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
           BorderThickness="1" CornerRadius="8"
           Background="{ThemeResource LayerFillColorDefaultBrush}">
        <Grid RowDefinitions="*,Auto" Padding="16" RowSpacing="12"
              Shadow="{x:Null}" Translation="0,0,0">

            <!-- Task list -->
            <ListView Grid.Row="0"
                      x:Name="TaskListView"
                      ItemsSource="{x:Bind Tasks}"
                      SelectionMode="None"
                      Margin="0,0,0,0">

                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="MinHeight" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListView.ItemContainerStyle>
                
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="local:TaskItem">
                        <Grid ColumnDefinitions="Auto,*,Auto"
                              Padding="4,0" ColumnSpacing="12">

                            <!-- Checkbox -->
                            <CheckBox Grid.Column="0"
                                      IsChecked="{x:Bind IsCompleted, Mode=TwoWay}"
                                      Checked="CheckBox_Changed"
                                      Unchecked="CheckBox_Changed"
                                      VerticalAlignment="Center"
                                      MinWidth="0"/>

                            <!-- Task title -->
                            <TextBlock Grid.Column="1"
                                       Text="{x:Bind Title, Mode=OneWay}"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap"
                                       Opacity="{x:Bind local:MainWindow.CompletedOpacity(IsCompleted), Mode=OneWay}"/>

                            <!-- Delete -->
                            <Button Grid.Column="2"
                                    Content="&#xE74D;"
                                    FontFamily="{StaticResource SymbolThemeFontFamily}"
                                    Click="DeleteTask_Click"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    VerticalAlignment="Center"
                                    ToolTipService.ToolTip="Delete task"
                                    Padding="8,4"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Add-task input -->
            <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBox x:Name="TaskInputBox"
                         Grid.Column="0"
                         PlaceholderText="What needs to be done?"
                         KeyDown="{x:Bind TaskInput_KeyDown}"
                         VerticalAlignment="Center"/>

                <Button Grid.Column="1"
                        Content="Add"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="{x:Bind AddTask_Click}"
                        VerticalAlignment="Center"
                        MinWidth="72"/>
            </Grid>

        </Grid>
    </Border>
</Window>
